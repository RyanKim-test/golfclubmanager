generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model Member {
  id             Int           @id @default(autoincrement())
  name           String
  email          String        @unique
  phone          String?
  membershipType String        @default("일반")
  joinedAt       DateTime      @default(now())
  reservations   Reservation[]
  scores         Score[]
}

model Reservation {
  id        Int      @id @default(autoincrement())
  memberId  Int
  member    Member   @relation(fields: [memberId], references: [id])
  course    String
  teeTime   DateTime
  players   Int      @default(1)
  status    String   @default("예약중")
  createdAt DateTime @default(now())
}

model Score {
  id        Int      @id @default(autoincrement())
  memberId  Int
  member    Member   @relation(fields: [memberId], references: [id])
  course    String
  playedAt  DateTime
  score     Int
  par       Int      @default(72)
  createdAt DateTime @default(now())
}
